{
  "permissions": {
    "allow": [
      "mcp__Claude_Code_Remote__send_later",
      "mcp__Claude_Code_Remote__delete_trigger",
      "mcp__Claude_Code_Remote__add_repo",
      "mcp__Claude_Code_Remote__register_repo_root",
      "Workflow(deep-research)",
      "Bash(mkdir -p ~/.claude)",
      "Bash(rm -f ~/.ssh/cm-cws*)",
      "Bash(ssh -o ConnectTimeout=10 cws-box 'echo BACK')"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh\"",
            "timeout": 120
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-pr-lint.sh\"",
            "timeout": 60
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/post-pr-simplify.sh\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
